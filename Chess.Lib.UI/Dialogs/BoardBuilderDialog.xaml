<dlg:DialogView x:Class="Chess.Lib.UI.Dialogs.BoardBuilderDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Chess.Lib.UI.Dialogs"
             xmlns:dlg="clr-namespace:Common.Lib.UI.Dialogs;assembly=Common.Lib.UI"
						 xmlns:ddm="clr-namespace:Common.Lib.UI.DragDrop.DDM;assembly=Common.Lib.UI"
						 xmlns:ctrls="clr-namespace:Common.Lib.UI.Controls;assembly=Common.Lib.UI.Controls"
						 xmlns:txt="clr-namespace:Common.Lib.UI.Controls.Text;assembly=Common.Lib.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Width="574" AnimationDuration="0.2" IsResizable="False">
	<dlg:DialogView.Resources>
		<DataTemplate x:Key="pieceTemplate">
			<local:DraggedPiece/>
		</DataTemplate>
		<local:NextMoveConverter x:Key="nmc"/>
	</dlg:DialogView.Resources>
	<dlg:DialogView.Header>
		<DockPanel LastChildFill="False">
			<TextBlock DockPanel.Dock="Left" Text="Build-A-Board" Foreground="Yellow" FontSize="16" FontStyle="Italic" Margin="2,0,6,0"/>
			<ctrls:InfoPopout DockPanel.Dock="Left" Width="30" Height="30" FontSize="14">
				<Border Background="LightSkyBlue">
					<Border Margin="2" Background="LightSkyBlue" BorderBrush="Navy" BorderThickness="1" Padding="2">
						<StackPanel>
							<StackPanel.Resources>
								<Style TargetType="TextBlock">
									<Setter Property="TextWrapping" Value="Wrap"/>
									<Setter Property="Margin" Value="0,5"/>
								</Style>
								<Style TargetType="{x:Type txt:BulletText}">
									<Setter Property="Bullet" Value="•"/>
									<Setter Property="TextWrapping" Value="Wrap"/>
								</Style>
							</StackPanel.Resources>
							<TextBlock Text="To place pieces:" FontWeight="Bold"/>
							<txt:BulletText Text="Drag any piece onto the board."/>
							<txt:BulletText Text="Drag a piece from any square to another."/>
							<txt:BulletText Text="Click on a piece while pressing shift to change the cursor, then click on any square."/>
							<txt:BulletText Text="To exit this mode, either press the Escape key or click on another piece."/>
							<Separator Background="Navy"/>
							<TextBlock Text="Board Validity" FontWeight="Bold"/>
							<txt:BulletText Text="A valid board contains two kings, with neither in checkmate."/>
							<txt:BulletText Text="A valid board contains enough material to bring checkmate."/>
						</StackPanel>
					</Border>
				</Border>
			</ctrls:InfoPopout>
			<ctrls:HyperLink Text="Copy FEN" UnderlineBehavior="UnderlineOnHover" Foreground="Red"
											 Command="{Binding Command}" CommandParameter="copyFEN"/>
		</DockPanel>
	</dlg:DialogView.Header>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid Grid.Row="0" Grid.Column="0" Height="{Binding ElementName=squares,Path=ActualHeight}" Name="pieces">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			<GroupBox Header="Black Pieces" Grid.Row="0" Margin="2">
				<ItemsControl ItemsSource="{Binding BlackPieces}" ItemTemplate="{StaticResource pieceTemplate}" VerticalAlignment="Top">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="2" Rows="3"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</GroupBox>
			<DockPanel Grid.Row="1">
				<ToggleButton DockPanel.Dock="Right" Width="30" Height="30" Style="{x:Null}" VerticalAlignment="Bottom" IsChecked="{Binding IsEraserActive}"
										ToolTip="Use this tool to erase squares" IsEnabled="{Binding HasPieces}" Margin="5">
					<Image Source="/Chess.Lib.UI;component/Images/eraser.png"/>
				</ToggleButton>
				<GroupBox Header="Next Move">
					<StackPanel Orientation="Horizontal">
						<CheckBox Content="White" IsChecked="{Binding NextMove,Converter={StaticResource nmc},ConverterParameter=l}"/>
						<CheckBox Content="Black" IsChecked="{Binding NextMove,Converter={StaticResource nmc},ConverterParameter=d}" Margin="5,0"/>
					</StackPanel>
				</GroupBox>
			</DockPanel>
			<GroupBox Grid.Row="2" Header="White Pieces" Margin="2">
				<ItemsControl ItemsSource="{Binding WhitePieces}" ItemTemplate="{StaticResource pieceTemplate}" VerticalAlignment="Bottom">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="2" Rows="3"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</GroupBox>
		</Grid>
		<ItemsControl Grid.Column="1" Grid.Row="0" BorderBrush="Navy" BorderThickness="1" ItemsSource="{Binding Squares}"
									Name="squares" Height="400" Width="400" Margin="3">
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<local:DropGrid>
						<Rectangle Fill="{Binding Fill}"/>
						<Image Source="{Binding Piece}"/>
					</local:DropGrid>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Rows="8" Columns="8"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
		</ItemsControl>
		<Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
			<Grid.Resources>
				<Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
					<Setter Property="Margin" Value="0,3"/>
				</Style>
			</Grid.Resources>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="{Binding ElementName=pieces,Path=ActualWidth}"/>
				<ColumnDefinition Width="{Binding ElementName=squares,Path=ActualWidth}"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
				<Button Content="OK" Command="{Binding Command}" CommandParameter="ok" IsDefault="True"/>
				<Button Content="Cancel" Command="{Binding Command}" CommandParameter="cancel" IsCancel="True"/>
			</StackPanel>
			<DockPanel Grid.Row="0" Grid.Column="1">
				<Label Content="FEN:"/>
				<Button DockPanel.Dock="Right" Content="{Binding FenLabel}" Command="{Binding Command}" CommandParameter="fen"/>
				<TextBox Text="{Binding Fen,UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
			</DockPanel>
			<DockPanel Grid.Row="1" Grid.Column="1" LastChildFill="False">
				<Button DockPanel.Dock="Right" Content="Set Classical" Command="{Binding Command}" CommandParameter="setClassical"/>
				<Button DockPanel.Dock="Right" Content="Clear" Command="{Binding Command}" CommandParameter="clear"/>
				<StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0" HorizontalAlignment="Center">
					<CheckBox Content="Verify board validity" IsChecked="{Binding VerifyBoardValidity}"/>
				</StackPanel>
			</DockPanel>
		</Grid>
	</Grid>
</dlg:DialogView>
