<dlg:DialogView x:Class="Chess.Lib.UI.Dialogs.NewGameDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Chess.Lib.UI.Dialogs"
             xmlns:dlg="clr-namespace:Common.Lib.UI.Dialogs;assembly=Common.Lib.UI"
						 xmlns:clock="clr-namespace:Chess.Lib.UI.Clock"
						 xmlns:chess="clr-namespace:Chess.Lib.UI"
						 xmlns:tkit="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" DialogButtons="All" Header="New Chess Game" MinWidth="500" IsResizable="False">
	<dlg:DialogView.Resources>
		<Style TargetType="{x:Type chess:MiniBoard}">
			<Setter Property="Width" Value="140"/>
			<Setter Property="Height" Value="140"/>
			<Setter Property="BorderBrush" Value="Navy"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="Board" Value="{Binding SampleBoard}"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
		<BooleanToVisibilityConverter x:Key="b2vc"/>
		<local:GameBoardTypeConverter x:Key="gbtc"/>
	</dlg:DialogView.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<TabControl Grid.Row="0">
			<TabItem Header="Game">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Label Grid.Row="0" Grid.Column="0"  Content="White Player:"/>
					<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding White}" Name="white"/>
					<Label Grid.Row="0" Grid.Column="2" Content="Black Player:"/>
					<TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Black}"/>
					<GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Header="Chess Board">
						<DockPanel>
							<Grid DockPanel.Dock="Bottom">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="2*"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<UniformGrid Grid.Column="0" Rows="3">
									<RadioButton Content="Classic Chess" IsChecked="{Binding BoardType,Converter={StaticResource gbtc},ConverterParameter=cl}" 
									GroupName="board" HorizontalAlignment="Left"/>
									<RadioButton HorizontalAlignment="Left"
															 IsChecked="{Binding BoardType,Converter={StaticResource gbtc},ConverterParameter=fr}" GroupName="board">
										<Grid>
											<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" 
												Visibility="{Binding BoardType,Converter={StaticResource gbtc},ConverterParameter=vis}">
												<Label Content="Chess960 #:"/>
												<tkit:IntegerUpDown Value="{Binding Chess960Number}" Minimum="1" Maximum="960" Width="60">
													<tkit:IntegerUpDown.RenderTransform>
														<ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
													</tkit:IntegerUpDown.RenderTransform>
												</tkit:IntegerUpDown>
											</StackPanel>
											<TextBlock Text="Chess960" Visibility="{Binding BoardType,Converter={StaticResource gbtc},ConverterParameter=siv}"/>
										</Grid>
									</RadioButton>
									<RadioButton Content="Custom Board" IsChecked="{Binding BoardType,Converter={StaticResource gbtc},ConverterParameter=cu}" 
															 GroupName="board" HorizontalAlignment="Left"/>
								</UniformGrid>
								<chess:MiniBoard Grid.Column="1"/>
							</Grid>
						</DockPanel>
					</GroupBox>
				</Grid>
      </TabItem>
			<TabItem>
				<TabItem.Header>
					<TextBlock Text="Clock" FontWeight="{Binding ClockSettings.ClockHeaderWeight}"/>
				</TabItem.Header>
				<clock:ClockSettingsView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" DataContext="{Binding ClockSettings}"/>
      </TabItem>
	</TabControl>
		<DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" LastChildFill="False">
			<Button Content="Create Game" Command="{Binding Command}" CommandParameter="ok" IsDefault="True"/>
			<Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding Command}" CommandParameter="cancel" IsCancel="True"/>
			<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
				<CheckBox Content="Save as Default Game" IsChecked="{Binding SaveAsDefault}"/>
			</StackPanel>
		</DockPanel>
	</Grid>
</dlg:DialogView>
