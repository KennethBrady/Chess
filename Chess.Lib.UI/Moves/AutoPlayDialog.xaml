<dlg:DialogView x:Class="Chess.Lib.UI.Moves.AutoPlayDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Chess.Lib.UI.Moves"
             xmlns:dlg="clr-namespace:Common.Lib.UI.Dialogs;assembly=Common.Lib.UI"
						 xmlns:conv="clr-namespace:Common.Lib.UI.Converters;assembly=Common.Lib.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Placement="TopRight" PlacementOffset="0,30"
						 IsModal="False" Header="Auto-Replay" MaxHeight="500" Animation="None" DialogButtons="Close" Padding="3">
	<dlg:DialogView.Resources>
		<local:AutoPlayTriggerConverter x:Key="aptc"/>
		<conv:InverseBooleanConverter x:Key="ibc"/>
	</dlg:DialogView.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<GroupBox Grid.Row="0" Grid.Column="0"  Header="Trigger" Padding="3" VerticalAlignment="Center">
			<UniformGrid Rows="2" VerticalAlignment="Center">
				<RadioButton Content="Timed" IsChecked="{Binding Trigger,Converter={StaticResource aptc},ConverterParameter=a}"/>
				<RadioButton Content="Key-Press" IsChecked="{Binding Trigger,Converter={StaticResource aptc},ConverterParameter=k}"/>
			</UniformGrid>
		</GroupBox>
		<StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
			<StackPanel Orientation="Horizontal">
				<Label Content="Interval (s):"/>
				<ComboBox ItemsSource="{Binding Intervals}" SelectedItem="{Binding Interval}" MinWidth="34" Width="34"/>
			</StackPanel>
			<Button Content="{Binding StartStopLabel}" Command="{Binding Command}" CommandParameter="start" Width="100" 
			HorizontalAlignment="Left" Margin="3,5,3,5"/>
		</StackPanel>
		<Button Grid.Row="0" Grid.Column="2" Content="Reset Game" Command="{Binding Command}" CommandParameter="reset" VerticalAlignment="Center"
						HorizontalAlignment="Center"/>
		<GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Header="Current Move">
			<ListBox ItemsSource="{Binding Moves}" SelectedItem="{Binding PreviousMove}" DisplayMemberPath="NumberedAlgebraicMove" 
							 SelectionMode="Single" MaxHeight="400" IsEnabled="{Binding IsRunning,Converter={StaticResource ibc}}">
				<ListBox.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="6" Rows="{Binding RowCount}"/>
					</ItemsPanelTemplate>
				</ListBox.ItemsPanel>
			</ListBox>
		</GroupBox>
	</Grid>
</dlg:DialogView>
