<win:AppWindow x:Class="ChessGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChessGame"
				xmlns:cui="clr-namespace:Chess.Lib.UI;assembly=Chess.Lib.UI"
				xmlns:win="clr-namespace:Common.Lib.UI.Windows;assembly=Common.Lib.UI"
				xmlns:ui="clr-namespace:Common.Lib.UI;assembly=Common.Lib.UI"
				xmlns:pgn="clr-namespace:Chess.Lib.UI.Pgn;assembly=Chess.Lib.UI"
				xmlns:models="clr-namespace:ChessGame.Models"
				xmlns:dlg="clr-namespace:Common.Lib.UI.Dialogs;assembly=Common.Lib.UI"
				xmlns:cdlg="clr-namespace:Chess.Lib.UI.Dialogs;assembly=Chess.Lib.UI"
        mc:Ignorable="d"
				Icon="king.ico" Height="450" Width="800" WindowState="Maximized" ModalBackground="#222222aa">
	<win:AppWindow.Menu>
		<Menu FontSize="14" VerticalAlignment="Center" VerticalContentAlignment="Center">
			<Menu.Resources>
				<Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
					<Setter Property="Command" Value="{Binding Command}"/>
				</Style>
			</Menu.Resources>
			<MenuItem Header="Game" Command="{x:Null}">
				<MenuItem Header="New ..." CommandParameter="newGame" InputGestureText="Ctrl-N"/>
				<MenuItem Header="Branch Game" CommandParameter="branchGame"/>
				<MenuItem Header="{Binding PauseLabel}" CommandParameter="pauseGame" InputGestureText="Ctrl-P"/>
				<Separator/>
				<MenuItem Header="Export as PGN ..." CommandParameter="exportPgn" InputGestureText="Ctrl-X"/>
				<MenuItem Header="Import PGN ..." CommandParameter="importPgn" InputGestureText="Ctrl-I"/>
			</MenuItem>
			<MenuItem Header="Moves" Command="{x:Null}">
				<MenuItem Header="Auto-Replay" CommandParameter="autoplay" InputGestureText="Ctrl-U"/>
				<Separator/>
				<MenuItem Header="Undo" CommandParameter="undo"/>
			</MenuItem>
			<MenuItem Header="Engine" Command="{x:Null}">
				<MenuItem Header="Evaluate..." Command="{Binding Command}" CommandParameter="evalutate"/>
			</MenuItem>
		</Menu>
	</win:AppWindow.Menu>
	<win:AppWindow.InputBindings>
		<KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding Command}" CommandParameter="newGame"/>
		<KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding Command}" CommandParameter="exportPgn"/>
		<KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding Command}" CommandParameter="importPgn"/>
		<KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding Command}" CommandParameter="pauseGame"/>
		<KeyBinding Key="U" Modifiers="Ctrl" Command="{Binding Command}" CommandParameter="autoplay"/>
	</win:AppWindow.InputBindings>
	<win:AppWindow.Dialogs>
		<win:DialogDef DialogType="{x:Type cdlg:NewGameDialog}" ModelType="{x:Type cdlg:NewGameDialogModel}" SettingsKey="NewGameDialogSettings"/>
		<win:DialogDef DialogType="{x:Type pgn:PgnEditorDialog}" ModelType="{x:Type pgn:PgnEditorModel}" SettingsKey="PgnDialogSettings"/>
		<win:DialogDef DialogType="{x:Type pgn:ImportPgnDialog}" ModelType="{x:Type pgn:ImportPgnModel}"/>
	</win:AppWindow.Dialogs>
	<win:AppWindow.DialogStyle>
		<Style TargetType="{x:Type dlg:DialogView}">
			<Setter Property="Background" Value="LightSkyBlue"/>
			<Setter Property="BorderBrush" Value="Navy"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="Foreground" Value="Navy"/>
			<Setter Property="Padding" Value="1"/>
			<Setter Property="TitleBackground" Value="Navy"/>
			<Setter Property="TitleForeground"  Value="Yellow"/>
			<Setter Property="Animation" Value="Fade"/>
		</Style>
	</win:AppWindow.DialogStyle>
	<Grid>
		<cui:ChessGame HorizontalAlignment="Center" VerticalAlignment="Center" BoardDimension="800"
											BorderBrush="Black" BorderThickness="1" Game="{Binding Game}">
			<cui:ChessGame.PauseGameBorderStyle>
				<Style TargetType="Border">
					<Setter Property="Background" Value="Red"/>
					<Setter Property="BorderBrush" Value="Navy"/>
					<Setter Property="BorderThickness" Value="4"/>
				</Style>
			</cui:ChessGame.PauseGameBorderStyle>
		</cui:ChessGame>
	</Grid>
</win:AppWindow>
