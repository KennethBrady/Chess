<dlg:DialogView x:Class="PgnImporter.ImportFileDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PgnImporter"
						 xmlns:dlg="clr-namespace:Common.Lib.UI.Dialogs;assembly=Common.Lib.UI"
						 xmlns:ctrls="clr-namespace:Common.Lib.UI.Controls;assembly=Common.Lib.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Header="Import PGN" Width="500" MinWidth="500" Placement="TopCenter">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Label Grid.Row="0" Grid.Column="0" Content="Import File:"/>
		<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}"/>
		<ctrls:StackedProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding Progress}" Margin="4" Height="30"
															Foreground="Black"/>
		<DockPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" LastChildFill="False">
			<Button Content="{Binding ButtonLabel}" Command="{Binding Command}" CommandParameter="parsePgn"/>
			<TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold"/>
			<Button DockPanel.Dock="Right" Content="Cancel" IsCancel="True" Command="{Binding Command}" CommandParameter="cancel"/>
		</DockPanel>
	</Grid>
</dlg:DialogView>
